# ============================================================
# Data Broker Platform — environment variables
# Copy to .env and fill in your values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Mainlayer API ---
# Your Mainlayer API key (get one at https://app.mainlayer.xyz)
MAINLAYER_API_KEY=ml_your_api_key_here

# Base URL for the Mainlayer API (default is the production endpoint)
MAINLAYER_BASE_URL=https://api.mainlayer.xyz

# HTTP timeout for Mainlayer API calls (seconds)
MAINLAYER_TIMEOUT_SECONDS=10

# --- Server ---
HOST=0.0.0.0
PORT=8000

# Enable auto-reload during development (set to false in production)
RELOAD=true

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Storage ---
# Path to JSON file used for local persistence.
# Leave empty to use pure in-memory storage (data lost on restart).
STORAGE_PATH=./data/datasets.json

# --- CORS ---
# Comma-separated list of allowed origins. Use * for development only.
CORS_ORIGINS=*
